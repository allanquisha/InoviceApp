PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
# Local dev:  postgresql://user:password@localhost:5432/fieldpay
# Railway:    injected automatically as DATABASE_URL
DATABASE_URL="postgresql://user:password@localhost:5432/fieldpay"

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=replace_with_64_char_random_hex_string

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com

# Frontend URL (dev only — not needed in production)
FRONTEND_URL=http://localhost:5173
